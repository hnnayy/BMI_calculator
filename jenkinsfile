import groovy.json.JsonSlurperClassic

// ================= HELPER METHODS =================
@NonCPS
def extractHashFromResponse(String response) {
    def matcher = response =~ /"hash"\s*:\s*"([^"]+)"/
    return matcher.find() ? matcher.group(1) : ""
}

@NonCPS
def cleanJsonString(String rawOutput) {
    int firstBrace = rawOutput.indexOf('{')
    int lastBrace  = rawOutput.lastIndexOf('}')
    if (firstBrace == -1 || lastBrace == -1) return null
    return rawOutput.substring(firstBrace, lastBrace + 1)
}

// ================= PIPELINE =================
pipeline {
    agent any

    parameters {
        choice(
            name: 'BUILD_TYPE',
            choices: ['release', 'debug'],
            description: 'Pilih Tipe Build (Gunakan Release untuk hasil audit yang akurat)'
        )
    }

    environment {
        ANDROID_HOME     = "C:\\Users\\SECULAB\\AppData\\Local\\Android\\Sdk"
        ANDROID_SDK_ROOT = "${ANDROID_HOME}"
        JAVA_HOME        = "C:\\Program Files\\Eclipse Adoptium\\jdk-17.0.16.8-hotspot"
        FLUTTER_HOME     = "C:\\flutter"

        PATH = "${env.FLUTTER_HOME}\\bin;${env.JAVA_HOME}\\bin;${env.ANDROID_HOME}\\tools;${env.ANDROID_HOME}\\platform-tools;${env.ANDROID_HOME}\\emulator;${env.PATH}"

        AVD_NAME         = "Pixel_4_XL_2"
        APP_PACKAGE      = "com.example.bmi_calculator"
        APK_OUTPUT_DIR   = "C:\\ApksGenerated"

        MOBSF_URL        = "http://localhost:8000"
        MOBSF_TOKEN      = "fe55f4207016d5c6515a1df3b80a710d5d3b40d679462b27e333b004598d75ac"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/hnnayy/BMI_calculator.git',
                    credentialsId: 'github-pat-global-test'
            }
        }

        stage('Prepare Workspace') {
            steps {
                bat 'if not exist apk-outputs mkdir apk-outputs'
                bat "if not exist \"${env.APK_OUTPUT_DIR}\" mkdir \"${env.APK_OUTPUT_DIR}\""
                bat 'taskkill /F /IM qemu-system-x86_64.exe /T || exit 0'
                bat 'adb kill-server && adb start-server'
            }
        }

        stage('Clean Folder') {
            steps {
                bat "del /Q \"${env.APK_OUTPUT_DIR}\\*\" || exit 0"
            }
        }

        stage('Build Application') {
            steps {
                bat 'git config --global --add safe.directory "%WORKSPACE%"'
                bat 'taskkill /F /IM java.exe || exit 0'
                bat "flutter config --jdk-dir \"${env.JAVA_HOME}\""
                bat 'flutter pub get'
                bat "flutter build apk --${params.BUILD_TYPE}"
            }
        }

        stage('SAST - Static Analysis (MobSF)') {
            steps {
                script {
                    def apkPath = "build/app/outputs/flutter-apk/app-${params.BUILD_TYPE}.apk"
                    echo "Uploading APK to MobSF..."

                    def uploadResponse = bat(
                        script: """
                        @curl -s -H "Authorization: ${env.MOBSF_TOKEN}" -F "file=@${apkPath}" ${env.MOBSF_URL}/api/v1/upload
                        """,
                        returnStdout: true
                    ).trim()

                    env.APK_HASH = extractHashFromResponse(uploadResponse)
                    if (!env.APK_HASH) error "MobSF upload failed."

                    echo "Scanning: ${env.APK_HASH}"
                    bat "@curl -s -X POST -H \"Authorization: ${env.MOBSF_TOKEN}\" --data \"hash=${env.APK_HASH}\" ${env.MOBSF_URL}/api/v1/scan"
                }
            }
        }

        stage('Start Emulator') {
            steps {
                script {
                    echo "Starting emulator..."
                    bat "start /b \"\" \"${env.ANDROID_HOME}\\emulator\\emulator.exe\" -avd \"${env.AVD_NAME}\" -no-window -no-audio -gpu swiftshader_indirect -wipe-data"
                    
                    echo "Waiting for device to be ready..."
                    bat "adb wait-for-device"
                    
                    // Tunggu boot benar-benar selesai
                    def bootStatus = ""
                    timeout(5) {
                        while(!bootStatus.contains("1")) {
                            bootStatus = bat(script: "adb shell getprop sys.boot_completed", returnStdout: true).trim()
                            sleep 5
                        }
                    }
                    echo "Emulator Ready."
                }
            }
        }

        stage('Install APK') {
            steps {
                script {
                    def timestamp  = new Date().format("dd-MM-yyyy_HH-mm-ss")
                    def sourcePath = "build\\app\\outputs\\flutter-apk\\app-${params.BUILD_TYPE}.apk"
                    def destPath   = "apk-outputs\\todo-${params.BUILD_TYPE}-${timestamp}.apk"

                    bat "copy \"${sourcePath}\" \"${destPath}\""
                    env.APK_PATH = destPath

                    bat(script: "adb uninstall ${env.APP_PACKAGE}", returnStatus: true)
                    bat "adb install -r \"${env.APK_PATH}\""
                }
            }
        }

        stage('DAST - Dynamic Analysis (MobSF)') {
            steps {
                script {
                    echo "Starting Dynamic Analysis..."
                    bat "@curl -s -X POST -H \"Authorization: ${env.MOBSF_TOKEN}\" --data \"hash=${env.APK_HASH}\" ${env.MOBSF_URL}/api/v1/dynamic/start_analysis"
                    
                    sleep 20
                    echo "Injecting Frida Hooks..."
                    // Perbaikan: Pastikan format parameter benar
                    bat """
                    @curl -s -X POST -H "Authorization: ${env.MOBSF_TOKEN}" ^
                    --data "hash=${env.APK_HASH}" ^
                    --data "default_hooks=api_monitor,ssl_pinning_bypass,root_bypass,debugger_check_bypass" ^
                    ${env.MOBSF_URL}/api/v1/frida/instrument
                    """

                    echo "Running Monkey..."
                    try {
                        // Mengurangi jumlah event agar tidak menyebabkan DeadSystemException
                        bat "adb shell monkey -p ${env.APP_PACKAGE} --pct-syskeys 0 --throttle 1000 -v 100"
                    } catch (Exception e) {
                        echo "Monkey encountered a minor issue but continuing..."
                    }

                    sleep 10
                    echo "Stopping Analysis..."
                    bat "@curl -s -X POST -H \"Authorization: ${env.MOBSF_TOKEN}\" --data \"hash=${env.APK_HASH}\" ${env.MOBSF_URL}/api/v1/dynamic/stop_analysis"
                }
            }
        }

        stage('Download Reports') {
            steps {
                script {
                    echo "Downloading SAST PDF..."
                    bat """
                    @curl -s -X POST -H "Authorization: ${env.MOBSF_TOKEN}" --data "hash=${env.APK_HASH}" ${env.MOBSF_URL}/api/v1/download_pdf -o sast_report.pdf
                    """

                    echo "Downloading DAST PDF..."
                    // Perbaikan: Gunakan endpoint API POST, bukan direktori static jika 404
                    def dastResult = bat(script: """
                    @curl -s -X POST -H "Authorization: ${env.MOBSF_TOKEN}" ^
                    --data "hash=${env.APK_HASH}" ^
                    ${env.MOBSF_URL}/api/v1/dynamic/download_pdf -o dast_report.pdf
                    """, returnStatus: true)
                    
                    if (dastResult != 0) {
                        echo "Warning: DAST PDF Download failed. Trying alternative URL..."
                        bat "curl -s ${env.MOBSF_URL}/dynamic_pdf/${env.APK_HASH}/ -o dast_report.pdf"
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                bat 'taskkill /F /IM qemu-system-x86_64.exe /T || exit 0'
            }
        }

        stage('Send Email Manual') {
    steps {
        writeFile file: 'send_email.ps1', text: '''
[System.Net.ServicePointManager]::SecurityProtocol = [System.Net.SecurityProtocolType]::Tls12

$smtpServer = "smtp.gmail.com"
$smtpPort = 587
$from = "syifaamaraqueen@gmail.com"
$to = "syifaamdh@gmail.com"
$password = "lyftygsebuyndied"

$mail = New-Object System.Net.Mail.MailMessage
$mail.From = $from
$mail.To.Add($to)
$mail.Subject = "Security Report Jenkins"
$mail.Body = "Laporan PDF terlampir"

$att1 = New-Object System.Net.Mail.Attachment("sast_report.pdf")
$att2 = New-Object System.Net.Mail.Attachment("dast_report.pdf")

$mail.Attachments.Add($att1)
$mail.Attachments.Add($att2)

$smtp = New-Object System.Net.Mail.SmtpClient($smtpServer, $smtpPort)
$smtp.EnableSsl = $true
$smtp.UseDefaultCredentials = $false
$smtp.Credentials = New-Object System.Net.NetworkCredential($from, $password)
$smtp.DeliveryMethod = [System.Net.Mail.SmtpDeliveryMethod]::Network
$smtp.Timeout = 30000

$smtp.Send($mail)
'''
        bat 'powershell -ExecutionPolicy Bypass -File send_email.ps1'
    }
}
    }

    post {
        always {
            archiveArtifacts artifacts: 'apk-outputs/*.apk, *.pdf', allowEmptyArchive: true
        }
    }
}